{
  "name": "@varolisto/shared-schemas",
  "packageManager": "pnpm@10.26.0",
  "version": "0.5.0",
  "description": "Shared Zod schemas and CLABE utilities for Varolisto applications",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./form": {
      "import": "./dist/esm/form/index.js",
      "require": "./dist/cjs/form/index.js",
      "types": "./dist/types/form/index.d.ts"
    },
    "./validators": {
      "import": "./dist/esm/validators/index.js",
      "require": "./dist/cjs/validators/index.js",
      "types": "./dist/types/validators/index.d.ts"
    },
    "./enums": {
      "import": "./dist/esm/enums/index.js",
      "require": "./dist/cjs/enums/index.js",
      "types": "./dist/types/enums/index.d.ts"
    },
    "./domain": {
      "import": "./dist/esm/domain/index.js",
      "require": "./dist/cjs/domain/index.js",
      "types": "./dist/types/domain/index.d.ts"
    },
    "./api": {
      "import": "./dist/esm/api/index.js",
      "require": "./dist/cjs/api/index.js",
      "types": "./dist/types/api/index.d.ts"
    },
    "./admin": {
      "import": "./dist/esm/admin/index.js",
      "require": "./dist/cjs/admin/index.js",
      "types": "./dist/types/admin/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.build.json --module NodeNext --outDir dist/esm",
    "build:cjs": "tsc -p tsconfig.build.json --module CommonJS --moduleResolution node --outDir dist/cjs",
    "build:types": "tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist/types",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "depcheck": "depcruise --config .dependency-cruiser.cjs src",
    "verify": "pnpm typecheck && pnpm depcheck && pnpm test:coverage && pnpm build",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@vitest/coverage-v8": "^2.1.9",
    "dependency-cruiser": "^16.10.4",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
